# Copy to `.env` in this directory (never commit `.env`).
# Or skip loading any file: DOTENV_CONFIG_PATH=/nonexistent npm start

# --- Core ---
# mock | bigquery
DATA_SOURCE=mock

# HTTP port for Express API
PORT=3000

# Optional shared secret. When unset, the API accepts requests without x-api-key (local demo).
# API_KEY=

# Comma-separated allowed browser origins for CORS.
CORS_ORIGIN=http://localhost:8000

# --- BigQuery (only when DATA_SOURCE=bigquery) ---
# BIGQUERY_PROJECT_ID=your-gcp-project-id
# BIGQUERY_LOCATION=US

# Path to service account JSON (optional if using Application Default Credentials).
# BIGQUERY_KEY_FILE=/absolute/path/to/service-account.json

# Fully-qualified table ids: `project.dataset.table`
# BIGQUERY_TABLE_SESSION_METADATA=your-project.analytics.session_metadata
# BIGQUERY_TABLE_LATENCY_EVENTS=your-project.analytics.latency_events
# BIGQUERY_TABLE_TTS_METRICS=your-project.analytics.tts_metrics
# BIGQUERY_TABLE_ASR_METRICS=your-project.analytics.asr_metrics
# BIGQUERY_TABLE_SESSION_ENRICHMENT=your-project.analytics.session_enrichment
